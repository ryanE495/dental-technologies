---
---

<section id="contact" class="contact-section">
  <div class="contact-container">
    <div class="contact-left">
      <h2 class="contact-title">let's work together</h2>
      <div class="gold-line"></div>
      <p class="contact-description">
        Ready to elevate your dental restorations? Get in touch with our team to discuss your case requirements, turnaround times, or to schedule a pickup.
      </p>
    </div>
    <div class="contact-right">
      <div class="cards-grid">
        <!-- Phone -->
        <div class="contact-card animate-on-scroll">
          <div class="card-line"></div>
          <div class="card-content">
            <div class="icon-circle">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <h3 class="card-heading">Phone</h3>
            <a href="tel:5550000000" class="card-link">(555) 000-0000</a>
            <span class="card-note">Mon–Fri 8AM–5PM</span>
          </div>
        </div>
        <!-- Email -->
        <div class="contact-card animate-on-scroll">
          <div class="card-line"></div>
          <div class="card-content">
            <div class="icon-circle">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <polyline points="22,7 12,13 2,7"/>
              </svg>
            </div>
            <h3 class="card-heading">Email</h3>
            <a href="mailto:info@dentaltechlab.com" class="card-link card-link-email">info@dentaltechlab.com</a>
            <span class="card-note">24hr response</span>
          </div>
        </div>
        <!-- Location -->
        <div class="contact-card animate-on-scroll">
          <div class="card-line"></div>
          <div class="card-content">
            <div class="icon-circle">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h3 class="card-heading">Location</h3>
            <span class="card-link">Local Dental Lab</span>
            <span class="card-note">Pickup & delivery available</span>
          </div>
        </div>
        <!-- Hours -->
        <div class="contact-card animate-on-scroll">
          <div class="card-line"></div>
          <div class="card-content">
            <div class="icon-circle">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12,6 12,12 16,14"/>
              </svg>
            </div>
            <h3 class="card-heading">Hours</h3>
            <span class="card-link">Monday–Friday</span>
            <span class="card-note">8:00 AM – 5:00 PM</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('#contact .animate-on-scroll').forEach((el) => observer.observe(el));
</script>

<style>
  .contact-section {
    background: #efeeea;
    padding: 4rem 0 2rem 0;
    overflow: hidden;
  }

  .contact-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-title {
    font-family: 'NeueHaasDisplayRoman', sans-serif;
    font-size: 2.5rem;
    color: #111827;
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .gold-line {
    width: 60px;
    height: 3px;
    background: #C8A96E;
    margin-bottom: 1.5rem;
  }

  .contact-description {
    font-family: 'NeueHaasDisplayThin', sans-serif;
    font-size: 1.05rem;
    color: #374151;
    line-height: 1.7;
    margin: 0;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .contact-card {
    background: #f8f9fa;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-align: center;
  }

  .contact-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 24px rgba(200, 169, 110, 0.25);
  }

  .card-line {
    height: 3px;
    background: linear-gradient(90deg, #C8A96E, #e8d5a8);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .contact-card:hover .card-line {
    transform: scaleX(1);
  }

  .card-content {
    padding: 1.75rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .icon-circle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #fff;
    border: 1px solid #E5E7EB;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111827;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease;
    margin-bottom: 0.25rem;
  }

  .contact-card:hover .icon-circle {
    background: #C8A96E;
    border-color: #C8A96E;
    color: #fff;
  }

  .card-heading {
    font-family: 'NeueHaasDisplayRoman', sans-serif;
    font-size: 1rem;
    color: #111827;
    margin: 0;
  }

  .card-link {
    font-family: 'NeueHaasDisplayThin', sans-serif;
    font-size: 0.95rem;
    color: #374151;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  a.card-link:hover {
    color: #C8A96E;
  }

  .card-link-email {
    word-break: break-all;
  }

  .card-note {
    font-family: 'NeueHaasDisplayThin', sans-serif;
    font-size: 0.8rem;
    color: #9CA3AF;
  }

  :global(.animate-on-scroll) {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  :global(.animate-on-scroll.visible) {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 768px) {
    .contact-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .contact-title {
      font-size: 2rem;
    }

    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
