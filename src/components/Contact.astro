---

<section id="contact" class="contact section-padding">
	<div class="container">
		<div class="contact-layout">
			<div class="left-side">
				<div class="section-header animate-on-scroll">
					<h2>let's work together</h2>
					<div class="accent-line"></div>
					<p class="cta-description">Ready to partner with a lab that puts quality first? Reach out — we'd love to hear about your practice.</p>
				</div>
				<div class="scroll-arrow">
					<svg width="48" height="42" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path id="contact-arrow-head" d="M8 12L24 24L40 12" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
						<path id="contact-arrow-stem" d="M24 12L24 22" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</div>
			</div>
			
			<div class="contact-cards">
				<div class="contact-item animate-on-scroll">
					<div class="contact-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" fill="none"/>
						</svg>
					</div>
					<div class="contact-details">
						<h3>Phone</h3>
						<a href="tel:+1-555-000-0000" class="contact-link">(555) 000-0000</a>
						<span class="contact-note">Mon–Fri, 8 AM – 5 PM</span>
					</div>
				</div>
				
				<div class="contact-item animate-on-scroll">
					<div class="contact-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" fill="none"/>
							<polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="2" fill="none"/>
						</svg>
					</div>
					<div class="contact-details">
						<h3>Email</h3>
						<a href="mailto:info@dentaltechlab.com" class="contact-link">info@dentaltechlab.com</a>
						<span class="contact-note">We respond within 24 hours</span>
					</div>
				</div>
				
				<div class="contact-item animate-on-scroll">
					<div class="contact-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2" fill="none"/>
							<circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" fill="none"/>
						</svg>
					</div>
					<div class="contact-details">
						<h3>Location</h3>
						<span class="contact-text">Local Dental Lab</span>
						<span class="contact-note">Pickup & delivery available</span>
					</div>
				</div>
				
				<div class="contact-item animate-on-scroll">
					<div class="contact-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none"/>
							<polyline points="12,6 12,12 16,14" stroke="currentColor" stroke-width="2" fill="none"/>
						</svg>
					</div>
					<div class="contact-details">
						<h3>Hours</h3>
						<span class="contact-text">Monday – Friday</span>
						<span class="contact-note">8:00 AM – 5:00 PM</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.contact { background: #efeeea; padding: 4rem 0; }
	.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
	.contact-layout { display: grid; grid-template-columns: 1fr 1.5fr; gap: 4rem; align-items: flex-start; }
	.left-side { position: sticky; top: 2rem; }
	.section-header h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 300; color: #111827; margin-bottom: 1.5rem; font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif; cursor: pointer; transition: color 0.3s ease; }
	.section-header h2:hover { color: #C8A96E; }
	.accent-line { width: 200px; height: 4px; background-color: #C8A96E; margin-bottom: 2rem; }
	.cta-description { font-size: 1.125rem; color: #6B7280; line-height: 1.6; font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif; }
	.scroll-arrow { margin-top: 2rem; margin-left: 3rem; color: #C8A96E; height: 120px; max-height: 600px; overflow: visible; pointer-events: none; }
	.scroll-arrow svg { height: auto; min-height: 32px; max-height: 600px; overflow: visible; width: 48px; }
	.contact-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
	.contact-item { background: #f8f9fa; padding: 2rem; border: 1px solid #E5E7EB; transition: all 0.3s ease; position: relative; overflow: hidden; text-align: center; }
	.contact-item::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 2px; background: linear-gradient(90deg, transparent, #C8A96E, transparent); transition: left 0.6s ease; }
	.contact-item:hover::before { left: 100%; }
	.contact-item:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(200, 169, 110, 0.1); background: white; }
	.contact-icon { width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem auto; color: #111827; background: white; border: 2px solid #E5E7EB; transition: all 0.3s ease; }
	.contact-item:hover .contact-icon { transform: scale(1.05); background: #C8A96E; color: white; border-color: #C8A96E; }
	.contact-details h3 { margin-bottom: 0.5rem; color: #111827; font-size: 1.125rem; font-weight: 500; }
	.contact-link { display: block; color: #374151; text-decoration: none; font-size: 0.9rem; font-weight: 500; margin-bottom: 0.5rem; transition: color 0.3s ease; word-break: break-all; }
	.contact-link:hover { color: #C8A96E; }
	.contact-text { display: block; color: #374151; font-size: 1rem; font-weight: 500; margin-bottom: 0.5rem; }
	.contact-note { font-size: 0.875rem; color: #9CA3AF; font-style: italic; font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif; }
	:global(.animate-on-scroll) { opacity: 0 !important; transform: translateY(30px) !important; transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1) !important; }
	:global(.animate-on-scroll.animate-in) { opacity: 1 !important; transform: translateY(0) !important; }
	@media (max-width: 1024px) {
		.contact-layout { grid-template-columns: 1fr; gap: 3rem; }
		.left-side { position: static; }
		.scroll-arrow { display: none; }
	}
	@media (max-width: 768px) {
		.contact { padding: 4rem 0; }
		.section-header { text-align: center; }
		.accent-line { margin-left: auto; margin-right: auto; }
		.cta-description { text-align: center; }
		.contact-cards { grid-template-columns: 1fr; gap: 1.5rem; }
		.contact-item { padding: 1.5rem; }
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const section = document.querySelector('#contact');
		if (!section) return;
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.querySelectorAll('.animate-on-scroll').forEach((el, i) => { setTimeout(() => el.classList.add('animate-in'), i * 150); });
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.2 });
		observer.observe(section);

		const arrowStem = document.querySelector('#contact-arrow-stem');
		const arrowHead = document.querySelector('#contact-arrow-head');
		const arrowContainer = document.querySelector('#contact .scroll-arrow');
		function updateArrow() {
			if (!arrowStem || !arrowHead || !section || !arrowContainer) return;
			const rect = section.getBoundingClientRect();
			const sh = section.offsetHeight, wh = window.innerHeight;
			let p = 0;
			if (rect.top <= wh && rect.bottom >= 0 && rect.top <= wh * 0.5) {
				p = Math.min(1, Math.max(0, wh * 0.5 - rect.top) / (sh * 0.8));
			}
			const h = 120 + (p * (Math.min(600, sh) - 120));
			arrowContainer.style.height = `${h}px`;
			const svg = arrowContainer.querySelector('svg');
			if (svg) { svg.setAttribute('viewBox', `0 0 48 ${Math.max(42, h)}`); svg.style.height = `${h}px`; }
			const stemEnd = 22 + (p * (h - 82));
			arrowStem.setAttribute('d', `M24 12L24 ${stemEnd}`);
			arrowHead.setAttribute('d', `M8 ${Math.max(12, stemEnd - 15)}L24 ${stemEnd}L40 ${Math.max(12, stemEnd - 15)}`);
		}
		window.addEventListener('scroll', updateArrow);
		updateArrow();
	});
</script>
