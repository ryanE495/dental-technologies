---
---

<section id="find-us" class="find-us section-padding">
	<div class="container">
		<div class="findus-layout">
			<div class="left-side">
				<div class="section-header animate-on-scroll">
					<h2>find us</h2>
					<div class="accent-line"></div>
					<p class="directions-text">We're located in a quiet residential setting — a deliberate choice that allows us to focus entirely on the craft. Don't let the address surprise you; the quality of work inside speaks for itself.</p>
				</div>
				<div class="scroll-arrow">
					<svg width="48" height="42" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path id="findus-arrow-head" d="M8 12L24 24L40 12" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
						<path id="findus-arrow-stem" d="M24 12L24 22" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</div>
			</div>
			
			<div class="right-content">
				<div class="map-block animate-on-scroll">
					<div class="map-wrapper">
						<iframe 
							src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d49731.41!2d-107.88!3d38.48!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDI4JzQ4LjAiTiAxMDfCsDUyJzQ4LjAiVw!5e0!3m2!1sen!2sus!4v1" 
							width="100%" 
							height="300" 
							style="border:0; filter: grayscale(60%) contrast(1.1);" 
							allowfullscreen="" 
							loading="lazy" 
							referrerpolicy="no-referrer-when-downgrade">
						</iframe>
					</div>
					<a href="https://maps.google.com" target="_blank" rel="noopener noreferrer" class="directions-button">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2" fill="none"/>
							<circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" fill="none"/>
						</svg>
						Get Directions
					</a>
				</div>
				
				<div class="prep-content animate-on-scroll">
					<h3>sending us a case</h3>
					<div class="prep-list">
						<div class="prep-item">
							<span class="prep-number">01</span>
							<p>Include a detailed prescription with shade, material preference, and any special instructions.</p>
						</div>
						<div class="prep-item">
							<span class="prep-number">02</span>
							<p>Ensure impressions or digital scans capture clear margins and opposing dentition.</p>
						</div>
						<div class="prep-item">
							<span class="prep-number">03</span>
							<p>Include bite registration and any relevant patient photos for shade reference.</p>
						</div>
						<div class="prep-item">
							<span class="prep-number">04</span>
							<p>Ship using our provided FedEx labels or drop off directly at our lab during business hours.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.find-us { background-color: #efeeea; padding: 6rem 0 3rem 0; }
	.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
	.findus-layout { display: grid; grid-template-columns: 1fr 1.5fr; gap: 4rem; align-items: flex-start; }
	.left-side { position: sticky; top: 2rem; }
	.section-header h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 300; color: #111827; margin-bottom: 1.5rem; font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif; cursor: pointer; transition: color 0.3s ease; }
	.section-header h2:hover { color: #C8A96E; }
	.accent-line { width: 200px; height: 4px; background-color: #C8A96E; margin-bottom: 2rem; }
	.directions-text { font-size: 1.125rem; line-height: 1.7; color: #6B7280; font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif; }
	.scroll-arrow { margin-top: 2rem; margin-left: 3rem; color: #C8A96E; height: 120px; max-height: 800px; overflow: visible; pointer-events: none; }
	.scroll-arrow svg { height: auto; min-height: 32px; max-height: 800px; overflow: visible; width: 48px; }
	.right-content { display: flex; flex-direction: column; gap: 3rem; }
	.map-block { display: flex; flex-direction: column; gap: 1.5rem; }
	.map-wrapper { width: 100%; overflow: hidden; border: 1px solid #E5E7EB; transition: all 0.3s ease; position: relative; }
	.map-wrapper:hover { box-shadow: 0 15px 35px rgba(200, 169, 110, 0.12); border-color: #C8A96E; }
	.map-wrapper iframe { display: block; width: 100%; }
	.directions-button { display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; background-color: #111827; color: white; text-decoration: none; font-size: 0.95rem; font-weight: 500; letter-spacing: 0.025em; text-transform: uppercase; transition: all 0.3s ease; }
	.directions-button:hover { background-color: #C8A96E; transform: translateY(-2px); box-shadow: 0 10px 25px rgba(200, 169, 110, 0.3); }
	.prep-content h3 { font-size: 1.5rem; font-weight: 300; color: #111827; margin-bottom: 2.5rem; font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif; }
	.prep-list { display: flex; flex-direction: column; gap: 2rem; }
	.prep-item { display: flex; gap: 1.5rem; align-items: flex-start; padding: 1.5rem; transition: all 0.3s ease; border-left: 2px solid transparent; }
	.prep-item:hover { background: rgba(200, 169, 110, 0.03); border-left-color: #C8A96E; transform: translateX(5px); }
	.prep-number { font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif; font-size: 0.8rem; color: #C8A96E; letter-spacing: 0.15em; flex-shrink: 0; padding-top: 0.2rem; }
	.prep-item p { font-size: 1rem; line-height: 1.6; color: #6B7280; font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif; }
	:global(.animate-on-scroll) { opacity: 0 !important; transform: translateY(30px) !important; transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1) !important; }
	:global(.animate-on-scroll.animate-in) { opacity: 1 !important; transform: translateY(0) !important; }
	@media (max-width: 1024px) {
		.findus-layout { grid-template-columns: 1fr; gap: 3rem; }
		.left-side { position: static; }
		.scroll-arrow { display: none; }
	}
	@media (max-width: 768px) {
		.find-us { padding: 4rem 0; }
		.section-header { text-align: center; }
		.accent-line { margin-left: auto; margin-right: auto; }
		.directions-text { text-align: center; }
		.directions-block { text-align: center; }
		.prep-item { padding: 1rem; }
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const section = document.querySelector('#find-us');
		if (!section) return;
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.querySelectorAll('.animate-on-scroll').forEach((el, i) => { setTimeout(() => el.classList.add('animate-in'), i * 200); });
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.2 });
		observer.observe(section);

		const arrowStem = document.querySelector('#findus-arrow-stem');
		const arrowHead = document.querySelector('#findus-arrow-head');
		const arrowContainer = document.querySelector('#find-us .scroll-arrow');
		function updateArrow() {
			if (!arrowStem || !arrowHead || !section || !arrowContainer) return;
			const rect = section.getBoundingClientRect();
			const sh = section.offsetHeight, wh = window.innerHeight;
			let p = 0;
			if (rect.top <= wh && rect.bottom >= 0 && rect.top <= wh * 0.5) {
				p = Math.min(1, Math.max(0, wh * 0.5 - rect.top) / (sh * 0.8));
			}
			const h = 120 + (p * (Math.min(800, sh) - 120));
			arrowContainer.style.height = `${h}px`;
			const svg = arrowContainer.querySelector('svg');
			if (svg) { svg.setAttribute('viewBox', `0 0 48 ${Math.max(42, h)}`); svg.style.height = `${h}px`; }
			const stemEnd = 22 + (p * (h - 82));
			arrowStem.setAttribute('d', `M24 12L24 ${stemEnd}`);
			arrowHead.setAttribute('d', `M8 ${Math.max(12, stemEnd - 15)}L24 ${stemEnd}L40 ${Math.max(12, stemEnd - 15)}`);
		}
		window.addEventListener('scroll', updateArrow);
		updateArrow();
	});
</script>
