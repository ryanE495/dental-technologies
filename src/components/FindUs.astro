---
---

<section id="find-us">
  <div class="findus-grid">
    <div class="left-content">
      <div class="left-text-block animate-on-scroll">
        <h2 class="section-title">find us</h2>
        <div class="gold-line"></div>
        <p class="description">
          We're located in a quiet residential area of Montrose, Colorado. Don't let the neighborhood fool you — behind our doors is a full-service dental laboratory equipped with the latest in digital and analog fabrication technology. If you're visiting for the first time, keep an eye out for our signage and feel free to call ahead for directions.
        </p>
      </div>
      <div class="arrow-container" id="findus-arrow-container">
        <svg viewBox="0 0 48 80" width="48" height="80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path id="findus-arrow-stem" d="M24 12L24 22" stroke="#C8A96E" stroke-width="2" stroke-linecap="round"/>
          <path id="findus-arrow-head" d="M8 12L24 22L40 12" stroke="#C8A96E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </div>
    </div>

    <div class="right-content">
      <div class="map-wrapper animate-on-scroll">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d49731.41!2d-107.88!3d38.48!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDI4JzQ4LjAiTiAxMDfCsDUyJzQ4LjAiVw!5e0!3m2!1sen!2sus!4v1"
          style="border:0; filter: grayscale(60%) contrast(1.1);"
          width="100%"
          height="300"
          loading="lazy"
          allowfullscreen=""
          referrerpolicy="no-referrer-when-downgrade"
          title="Dental Technologies Location"
        ></iframe>
      </div>

      <a class="directions-btn animate-on-scroll" href="https://www.google.com/maps/dir//38.48,-107.88" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="3 11 22 2 13 21 11 13 3 11"/>
        </svg>
        GET DIRECTIONS
      </a>

      <div class="case-section animate-on-scroll">
        <h3 class="case-title">sending us a case</h3>
        <div class="steps">
          <div class="step">
            <span class="step-number">01</span>
            <div class="step-content">
              <h4>Include a detailed prescription</h4>
              <p>Specify shade, material preference, and any special instructions. The more detail you provide — including tooth numbers, restoration type, and occlusal considerations — the better we can match your vision.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">02</span>
            <div class="step-content">
              <h4>Ensure impressions or scans capture clear margins</h4>
              <p>Whether you're sending PVS impressions or digital STL files, clean and well-defined margin lines are critical. Retract tissue as needed and verify capture before sending.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">03</span>
            <div class="step-content">
              <h4>Include bite registration &amp; patient photos</h4>
              <p>An accurate bite registration helps us set the case correctly. Patient photos — especially smile and retracted views — allow us to match shade and characterization to the individual.</p>
            </div>
          </div>
          <div class="step">
            <span class="step-number">04</span>
            <div class="step-content">
              <h4>Ship with FedEx labels or drop off in person</h4>
              <p>Use our prepaid FedEx shipping labels for convenient pickup, or drop cases off at our lab during business hours. We'll confirm receipt and estimated turnaround upon arrival.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #find-us {
    background: #efeeea;
    padding: 4rem 0 2rem 0;
    overflow: hidden;
  }

  .findus-grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }

  .left-content {
    position: relative;
    overflow: hidden;
  }

  .left-text-block {
    position: relative;
    z-index: 1;
  }

  .section-title {
    font-family: 'NeueHaasDisplayLight', 'Helvetica Neue', sans-serif;
    font-size: 2.8rem;
    font-weight: 300;
    color: #111827;
    text-transform: lowercase;
    letter-spacing: -0.02em;
    margin: 0 0 1rem 0;
  }

  .gold-line {
    width: 48px;
    height: 2px;
    background: #C8A96E;
    margin-bottom: 1.5rem;
  }

  .description {
    font-family: 'NeueHaasDisplayThin', 'Helvetica Neue', sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #6B7280;
    margin: 0;
  }

  .arrow-container {
    position: absolute;
    top: 0;
    left: 24px;
    width: 48px;
    height: 80px;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
    margin-top: 1rem;
    top: auto;
    bottom: 0;
    transform: translateY(0);
  }

  .arrow-container svg {
    display: block;
  }

  /* Map */
  .map-wrapper {
    border: 1px solid #d1cfc9;
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .map-wrapper:hover {
    border-color: #C8A96E;
    box-shadow: 0 0 0 1px #C8A96E;
  }

  .map-wrapper iframe {
    display: block;
    width: 100%;
  }

  /* Directions Button */
  .directions-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 0.75rem 1.5rem;
    background: #111827;
    color: #efeeea;
    text-decoration: none;
    font-family: 'NeueHaasDisplayLight', 'Helvetica Neue', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid transparent;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .directions-btn:hover {
    background: transparent;
    color: #C8A96E;
    border-color: #C8A96E;
  }

  /* Case Section */
  .case-section {
    margin-top: 2.5rem;
  }

  .case-title {
    font-family: 'NeueHaasDisplayLight', 'Helvetica Neue', sans-serif;
    font-size: 1.3rem;
    font-weight: 300;
    color: #111827;
    text-transform: lowercase;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem 0;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .step {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    padding-left: 1.25rem;
    border-left: 2px solid transparent;
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .step:hover {
    border-left-color: #C8A96E;
    background: rgba(200, 169, 110, 0.04);
  }

  .step-number {
    font-family: 'NeueHaasDisplayLight', 'Helvetica Neue', sans-serif;
    font-size: 1.5rem;
    font-weight: 300;
    color: #C8A96E;
    line-height: 1;
    flex-shrink: 0;
    width: 2rem;
    padding-top: 0.15rem;
  }

  .step-content h4 {
    font-family: 'NeueHaasDisplayLight', 'Helvetica Neue', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    color: #111827;
    margin: 0 0 0.4rem 0;
  }

  .step-content p {
    font-family: 'NeueHaasDisplayThin', 'Helvetica Neue', sans-serif;
    font-size: 0.88rem;
    line-height: 1.6;
    color: #6B7280;
    margin: 0;
  }

  /* Animate on scroll */
  :global(.animate-on-scroll) {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  :global(.animate-on-scroll.visible) {
    opacity: 1;
    transform: translateY(0);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .findus-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .left-content {
      text-align: center;
    }

    .gold-line {
      margin-left: auto;
      margin-right: auto;
    }

    .arrow-container {
      display: none;
    }

    .section-title {
      font-size: 2.2rem;
    }

    .directions-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('find-us');
    const arrowContainer = document.getElementById('findus-arrow-container');
    const arrowStem = document.getElementById('findus-arrow-stem');
    const arrowHead = document.getElementById('findus-arrow-head');
    const rightCol = document.querySelector('#find-us .right-content') as HTMLElement | null;

    function updateArrow() {
      if (!arrowStem || !arrowHead || !section || !arrowContainer) return;
      const rect = section.getBoundingClientRect();
      const maxH = rightCol ? rightCol.offsetHeight - 40 : 400;
      const wh = window.innerHeight;
      let p = 0;
      if (rect.top <= wh && rect.bottom >= 0 && rect.top <= wh * 0.5) {
        p = Math.min(1, Math.max(0, (wh * 0.5 - rect.top) / (maxH * 1.5)));
      }
      const h = 80 + (p * (maxH - 80));
      arrowContainer.style.height = h + 'px';
      const svg = arrowContainer.querySelector('svg');
      if (svg) {
        svg.setAttribute('viewBox', '0 0 48 ' + Math.max(42, h));
        svg.style.height = h + 'px';
      }
      const stemEnd = 22 + (p * (h - 60));
      arrowStem.setAttribute('d', 'M24 12L24 ' + stemEnd);
      arrowHead.setAttribute('d', 'M8 ' + Math.max(12, stemEnd - 12) + 'L24 ' + stemEnd + 'L40 ' + Math.max(12, stemEnd - 12));
    }

    window.addEventListener('scroll', updateArrow);
    updateArrow();

    // Animate on scroll observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('#find-us .animate-on-scroll').forEach(el => observer.observe(el));
  });
</script>
