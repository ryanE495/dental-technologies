---
---

<section id="find-us" class="find-us section-padding">
	<div class="container">
		<div class="find-us-layout">
			<div class="directions-content animate-on-scroll">
				<h2>find us</h2>
				<div class="accent-line"></div>
				<p class="directions-text">We're located in a quiet residential setting — a deliberate choice that allows us to focus entirely on the craft. Don't let the address surprise you; the quality of work inside speaks for itself.</p>
				
				<a href="https://maps.google.com" target="_blank" rel="noopener noreferrer" class="directions-button">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2" fill="none"/>
						<circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" fill="none"/>
					</svg>
					Get Directions
				</a>
			</div>
			
			<div class="prep-content animate-on-scroll">
				<h3>sending us a case</h3>
				<div class="prep-list">
					<div class="prep-item">
						<span class="prep-number">01</span>
						<p>Include a detailed prescription with shade, material preference, and any special instructions.</p>
					</div>
					<div class="prep-item">
						<span class="prep-number">02</span>
						<p>Ensure impressions or digital scans capture clear margins and opposing dentition.</p>
					</div>
					<div class="prep-item">
						<span class="prep-number">03</span>
						<p>Include bite registration and any relevant patient photos for shade reference.</p>
					</div>
					<div class="prep-item">
						<span class="prep-number">04</span>
						<p>Ship using our provided FedEx labels or drop off directly at our lab during business hours.</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.find-us {
		background-color: #efeeea;
		padding: 8rem 0;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.find-us-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 6rem;
		align-items: start;
	}

	.directions-content h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 300;
		color: #111827;
		margin-bottom: 1.5rem;
		font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif;
	}

	.accent-line {
		width: 200px;
		height: 4px;
		background-color: #C8A96E;
		margin-bottom: 3rem;
	}

	.directions-text {
		font-size: 1.125rem;
		line-height: 1.7;
		color: #6B7280;
		margin-bottom: 3rem;
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
	}

	.directions-button {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem 2rem;
		background-color: #111827;
		color: white;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		letter-spacing: 0.025em;
		text-transform: uppercase;
		transition: all 0.3s ease;
	}

	.directions-button:hover {
		background-color: #C8A96E;
		transform: translateY(-2px);
		box-shadow: 0 10px 25px rgba(200, 169, 110, 0.3);
	}

	.prep-content h3 {
		font-size: 1.5rem;
		font-weight: 300;
		color: #111827;
		margin-bottom: 2.5rem;
		font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif;
	}

	.prep-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.prep-item {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
		padding: 1.5rem;
		transition: all 0.3s ease;
		border-left: 2px solid transparent;
	}

	.prep-item:hover {
		background: rgba(55, 65, 81, 0.02);
		border-left-color: #C8A96E;
		transform: translateX(5px);
	}

	.prep-number {
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
		font-size: 0.8rem;
		color: #9CA3AF;
		letter-spacing: 0.15em;
		flex-shrink: 0;
		padding-top: 0.2rem;
	}

	.prep-item p {
		font-size: 1rem;
		line-height: 1.6;
		color: #6B7280;
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
	}

	@media (max-width: 768px) {
		.find-us {
			padding: 4rem 0;
		}

		.find-us-layout {
			grid-template-columns: 1fr;
			gap: 4rem;
		}

		.directions-content {
			text-align: center;
		}

		.accent-line {
			margin-left: auto;
			margin-right: auto;
		}

		.directions-button {
			margin: 0 auto;
		}

		.prep-item {
			padding: 1rem;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const section = document.querySelector('#find-us');
		if (!section) return;

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const elements = entry.target.querySelectorAll('.animate-on-scroll');
					elements.forEach((el, i) => {
						setTimeout(() => el.classList.add('animate-in'), i * 200);
					});
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.2 });

		observer.observe(section);
	});
</script>
