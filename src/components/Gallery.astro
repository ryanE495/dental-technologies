				</div>
			</div>
			
			<div class="gallery-item animate-on-scroll">
				<div class="gallery-placeholder">
					<div class="split">
						<span class="label">before</span>
					</div>
					<div class="divider"></div>
					<div class="split">
						<span class="label">after</span>
					</div>
				</div>
			</div>
			
			<div class="gallery-item animate-on-scroll">
				<div class="gallery-placeholder">
					<div class="split">
