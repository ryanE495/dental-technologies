						</div>
						<div class="img-half">
							<img src="/images/dental-after-1.jpg" alt="Crown restoration - after" />
							<span class="label">after</span>
						</div>
					</div>
					<div class="gallery-caption">Crown Restoration</div>
				</div>
			</div>
			
			<div class="gallery-item animate-on-scroll">
				<div class="gallery-card">
					<div class="gallery-images">
						<div class="img-half">
							<img src="/images/dental-before-2.jpg" alt="Veneer case - before" />
							<span class="label">before</span>
						</div>
						<div class="img-half">
							<img src="/images/dental-after-2.jpg" alt="Veneer case - after" />
							<span class="label">after</span>
						</div>
					</div>
					<div class="gallery-caption">Porcelain Veneers</div>
				</div>
			</div>
			
			<div class="gallery-item animate-on-scroll">
				<div class="gallery-card">
					<div class="gallery-images">
						<div class="img-half">
							<img src="/images/dental-before-3.jpg" alt="Bridge work - before" />
							<span class="label">before</span>
						</div>
						<div class="img-half">
							<img src="/images/dental-after-3.jpg" alt="Bridge work - after" />
							<span class="label">after</span>
						</div>
					</div>
					<div class="gallery-caption">Bridge Fabrication</div>
				</div>
			</div>
			
			<div class="gallery-item animate-on-scroll">
				<div class="gallery-card">
					<div class="gallery-images">
						<div class="img-half">
							<img src="/images/dental-before-4.jpg" alt="Implant case - before" />
							<span class="label">before</span>
						</div>
						<div class="img-half">
							<img src="/images/dental-after-4.jpg" alt="Implant case - after" />
							<span class="label">after</span>
						</div>
					</div>
					<div class="gallery-caption">Implant Restoration</div>
				</div>
			</div>
			
			<div class="gallery-item animate-on-scroll">
				<div class="gallery-card">
					<div class="gallery-images">
						<div class="img-half">
							<img src="/images/dental-before-5.jpg" alt="Custom shade - before" />
							<span class="label">before</span>
						</div>
						<div class="img-half">
							<img src="/images/dental-after-5.jpg" alt="Custom shade - after" />
							<span class="label">after</span>
						</div>
					</div>
					<div class="gallery-caption">Custom Shade Match</div>
				</div>
			</div>
			
			<div class="gallery-item animate-on-scroll">
				<div class="gallery-card">
					<div class="gallery-images">
						<div class="img-half">
							<img src="/images/dental-before-6.jpg" alt="Full denture - before" />
							<span class="label">before</span>
						</div>
