---

<section id="gallery" class="gallery section-padding">
	<div class="container">
		<div class="gallery-layout">
			<div class="left-side">
				<div class="section-header animate-on-scroll">
					<h2>see our work</h2>
					<div class="accent-line"></div>
					<p class="section-subtitle">Before and after results that speak for themselves</p>
				</div>
				<div class="scroll-arrow">
					<svg width="48" height="42" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path id="gallery-arrow-head" d="M8 12L24 24L40 12" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
						<path id="gallery-arrow-stem" d="M24 12L24 22" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</div>
			</div>
			
			<div class="gallery-cards">
				<div class="gallery-item animate-on-scroll">
					<div class="gallery-card">
						<div class="gallery-images">
							<div class="img-half"><img src="/images/dental-before-1.jpg" alt="Crown restoration - before" /><span class="label">before</span></div>
							<div class="img-half"><img src="/images/dental-after-1.jpg" alt="Crown restoration - after" /><span class="label">after</span></div>
						</div>
						<div class="gallery-caption">Crown Restoration</div>
					</div>
				</div>
				<div class="gallery-item animate-on-scroll">
					<div class="gallery-card">
						<div class="gallery-images">
							<div class="img-half"><img src="/images/dental-before-2.jpg" alt="Veneer case - before" /><span class="label">before</span></div>
							<div class="img-half"><img src="/images/dental-after-2.jpg" alt="Veneer case - after" /><span class="label">after</span></div>
						</div>
						<div class="gallery-caption">Porcelain Veneers</div>
					</div>
				</div>
				<div class="gallery-item animate-on-scroll">
					<div class="gallery-card">
						<div class="gallery-images">
							<div class="img-half"><img src="/images/dental-before-3.jpg" alt="Bridge work - before" /><span class="label">before</span></div>
							<div class="img-half"><img src="/images/dental-after-3.jpg" alt="Bridge work - after" /><span class="label">after</span></div>
						</div>
						<div class="gallery-caption">Bridge Fabrication</div>
					</div>
				</div>
				<div class="gallery-item animate-on-scroll">
					<div class="gallery-card">
						<div class="gallery-images">
							<div class="img-half"><img src="/images/dental-before-4.jpg" alt="Implant case - before" /><span class="label">before</span></div>
							<div class="img-half"><img src="/images/dental-after-4.jpg" alt="Implant case - after" /><span class="label">after</span></div>
						</div>
						<div class="gallery-caption">Implant Restoration</div>
					</div>
				</div>
				<div class="gallery-item animate-on-scroll">
					<div class="gallery-card">
						<div class="gallery-images">
							<div class="img-half"><img src="/images/dental-before-5.jpg" alt="Custom shade - before" /><span class="label">before</span></div>
							<div class="img-half"><img src="/images/dental-after-5.jpg" alt="Custom shade - after" /><span class="label">after</span></div>
						</div>
						<div class="gallery-caption">Custom Shade Match</div>
					</div>
				</div>
				<div class="gallery-item animate-on-scroll">
					<div class="gallery-card">
						<div class="gallery-images">
							<div class="img-half"><img src="/images/dental-before-6.jpg" alt="Full denture - before" /><span class="label">before</span></div>
							<div class="img-half"><img src="/images/dental-after-6.jpg" alt="Full denture - after" /><span class="label">after</span></div>
						</div>
						<div class="gallery-caption">Full Denture</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.gallery { background-color: #efeeea; padding: 4rem 0; }
	.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
	.gallery-layout { display: grid; grid-template-columns: 1fr 1.5fr; gap: 4rem; align-items: flex-start; }
	.left-side { position: sticky; top: 2rem; }
	.section-header h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 300; color: #111827; margin-bottom: 1.5rem; font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif; cursor: pointer; transition: color 0.3s ease; }
	.section-header h2:hover { color: #C8A96E; }
	.accent-line { width: 200px; height: 4px; background-color: #C8A96E; margin-bottom: 2rem; }
	.section-subtitle { font-size: 1.125rem; line-height: 1.6; color: #6B7280; font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif; }
	.scroll-arrow { margin-top: 2rem; margin-left: 3rem; color: #C8A96E; height: 120px; max-height: 1200px; overflow: visible; pointer-events: none; }
	.scroll-arrow svg { height: auto; min-height: 32px; max-height: 1200px; overflow: visible; width: 48px; }
	.gallery-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
	.gallery-item { transition: all 0.3s ease; }
	.gallery-item:hover { transform: translateY(-5px); }
	.gallery-card { background: white; border: 1px solid #E5E7EB; overflow: hidden; transition: all 0.3s ease; }
	.gallery-item:hover .gallery-card { box-shadow: 0 15px 35px rgba(200, 169, 110, 0.12); border-color: #C8A96E; }
	.gallery-images { display: flex; height: 180px; }
	.img-half { flex: 1; position: relative; overflow: hidden; }
	.img-half img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
	.gallery-item:hover .img-half img { transform: scale(1.05); }
	.img-half:first-child { border-right: 2px solid #C8A96E; }
	.label { position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; color: white; font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif; background: rgba(0, 0, 0, 0.5); padding: 0.25rem 0.75rem; backdrop-filter: blur(4px); }
	.gallery-caption { padding: 1rem 1.5rem; font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif; font-size: 0.9rem; color: #374151; text-align: center; letter-spacing: 0.025em; }
	:global(.animate-on-scroll) { opacity: 0 !important; transform: translateY(30px) !important; transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1) !important; }
	:global(.animate-on-scroll.animate-in) { opacity: 1 !important; transform: translateY(0) !important; }
	@media (max-width: 1024px) {
		.gallery-layout { grid-template-columns: 1fr; gap: 3rem; }
		.left-side { position: static; }
		.scroll-arrow { display: none; }
		.gallery-cards { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 768px) {
		.gallery { padding: 4rem 0; }
		.section-header { text-align: center; }
		.accent-line { margin-left: auto; margin-right: auto; }
		.gallery-cards { grid-template-columns: 1fr; gap: 1.5rem; }
		.gallery-images { height: 160px; }
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const section = document.querySelector('#gallery');
		if (!section) return;
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					entry.target.querySelectorAll('.animate-on-scroll').forEach((el, i) => { setTimeout(() => el.classList.add('animate-in'), i * 100); });
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.2 });
		observer.observe(section);

		const arrowStem = document.querySelector('#gallery-arrow-stem');
		const arrowHead = document.querySelector('#gallery-arrow-head');
		const arrowContainer = document.querySelector('#gallery .scroll-arrow');
		function updateArrow() {
			if (!arrowStem || !arrowHead || !section || !arrowContainer) return;
			const rect = section.getBoundingClientRect();
			const sh = section.offsetHeight, wh = window.innerHeight;
			let p = 0;
			if (rect.top <= wh && rect.bottom >= 0 && rect.top <= wh * 0.5) {
				p = Math.min(1, Math.max(0, wh * 0.5 - rect.top) / (sh * 0.8));
			}
			const h = 120 + (p * (Math.min(1200, sh) - 120));
			arrowContainer.style.height = `${h}px`;
			const svg = arrowContainer.querySelector('svg');
			if (svg) { svg.setAttribute('viewBox', `0 0 48 ${Math.max(42, h)}`); svg.style.height = `${h}px`; }
			const stemEnd = 22 + (p * (h - 82));
			arrowStem.setAttribute('d', `M24 12L24 ${stemEnd}`);
			arrowHead.setAttribute('d', `M8 ${Math.max(12, stemEnd - 15)}L24 ${stemEnd}L40 ${Math.max(12, stemEnd - 15)}`);
		}
		window.addEventListener('scroll', updateArrow);
		updateArrow();
	});
</script>
