<style>
	.gallery {
		background-color: #efeeea;
		padding: 8rem 0;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.section-header {
		text-align: left;
		margin-bottom: 5rem;
		padding-left: 2rem;
	}

	.section-header h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 300;
		line-height: 1.3;
		color: #111827;
		margin-bottom: 1.5rem;
		letter-spacing: -0.01em;
		font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif;
	}

	.accent-line {
		width: 200px;
		height: 4px;
		background-color: #C8A96E;
		margin-bottom: 2rem;
	}

	.section-subtitle {
		font-size: 1.125rem;
		line-height: 1.6;
		color: #6B7280;
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.gallery-item {
		transition: all 0.3s ease;
	}

	.gallery-item:hover {
		transform: translateY(-3px);
	}

	.gallery-placeholder {
		display: flex;
		height: 220px;
		background: rgba(55, 65, 81, 0.03);
		border: 1px solid #E5E7EB;
		overflow: hidden;
		transition: all 0.3s ease;
	}

	.gallery-item:hover .gallery-placeholder {
		box-shadow: 0 10px 30px rgba(200, 169, 110, 0.12);
		border-color: #C8A96E;
	}

	.split {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.divider {
		width: 1px;
		background: #D1D5DB;
	}

	.label {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: #9CA3AF;
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
	}

	@media (max-width: 1024px) {
		.gallery-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.gallery {
			padding: 4rem 0;
		}

		.section-header {
			text-align: center;
			padding-left: 0;
		}

		.accent-line {
			margin-left: auto;
			margin-right: auto;
		}

		.gallery-grid {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.gallery-placeholder {
			height: 180px;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const section = document.querySelector('#gallery');
		if (!section) return;

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const elements = entry.target.querySelectorAll('.animate-on-scroll');
					elements.forEach((el, i) => {
						setTimeout(() => el.classList.add('animate-in'), i * 100);
					});
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.2 });

		observer.observe(section);
	});
</script>
