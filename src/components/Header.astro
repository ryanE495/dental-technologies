---
---

<header class="header">
	<nav class="nav">
		<div class="container">
			<div class="nav-content">
				<a href="/" class="logo">
					<div class="logo-circle">
						<span class="logo-text">DTL</span>
					</div>
				</a>
				
				<div class="nav-links">
					<a href="#contact" class="contact-link">Contact</a>
					<div class="hamburger-container">
						<input type="checkbox" id="hamburger-toggle" class="hamburger-input" />
						<label for="hamburger-toggle" class="hamburger-btn" aria-label="Toggle menu">
							<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="hamburger-svg" aria-hidden="true">
								<circle class="hamburger-ring" cx="12" cy="12" r="11" />
								<path class="hamburger-line line-1" d="M4 7h16" />
								<path class="hamburger-line line-2" d="M4 12h16" />
								<path class="hamburger-line line-3" d="M4 17h16" />
							</svg>
						</label>
					</div>

					<div class="menu-overlay">
						<div class="menu-content">
							<nav class="menu-nav">
								<a href="#about" class="menu-link">who we are</a>
								<a href="#services" class="menu-link">services</a>
								<a href="#gallery" class="menu-link">our work</a>
								<a href="#find-us" class="menu-link">find us</a>
								<a href="#contact" class="menu-link">contact</a>
							</nav>
						</div>
					</div>
				</div>
			</div>
		</div>
	</nav>
</header>

<style>
	.header {
		position: static;
		background: #f8f9fa;
		border-bottom: 1px solid #E5E7EB;
	}

	.nav {
		padding: 1rem 0;
	}

	.nav-content {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		display: flex;
		align-items: center;
		text-decoration: none;
		color: #111827;
	}

	.logo-circle {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		border: 2px solid #C8A96E;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s ease;
	}

	.logo:hover .logo-circle {
		border-color: #C8A96E;
		transform: scale(1.05);
	}

	.logo-text {
		font-family: 'NeueHaasDisplayMedium', 'Inter', sans-serif;
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		color: #C8A96E;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.contact-link {
		color: #374151;
		text-decoration: none;
		font-size: 1rem;
		font-weight: 500;
		transition: color 0.3s ease;
		letter-spacing: 0.025em;
	}

	.contact-link:hover {
		color: #C8A96E;
	}

	.hamburger-container {
		position: relative;
	}

	.hamburger-input {
		display: none;
	}

	.hamburger-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		background: none;
		border: none;
		cursor: pointer;
		padding: 12px;
		z-index: 1003;
		position: relative;
		width: 64px;
		height: 64px;
		border-radius: 50%;
		transition: all 0.25s ease;
		background: rgba(17, 24, 39, 0.04);
	}

	.hamburger-btn:hover {
		background: rgba(200, 169, 110, 0.1);
		transform: scale(1.05);
	}

	.hamburger-svg {
		width: 200px;
		height: 200px;
		transition: transform 0.25s ease;
	}

	.hamburger-ring {
		fill: rgba(255, 255, 255, 0.2);
		stroke: transparent;
		opacity: 0;
		transition: opacity 0.2s ease;
	}

	.hamburger-line {
		fill: none;
		stroke: #111827;
		stroke-width: 2.5;
		stroke-linecap: round;
		vector-effect: non-scaling-stroke;
		transition: transform 0.25s ease, opacity 0.25s ease;
		transform-origin: center;
	}

	.line-1 { transform-origin: 12px 8px; }
	.line-2 { transform-origin: 12px 12px; }
	.line-3 { transform-origin: 12px 16px; }

	.hamburger-btn:hover .hamburger-ring { opacity: 1; }

	.hamburger-input:checked + .hamburger-btn {
		background: rgba(200, 169, 110, 0.15);
		transform: scale(1.05);
	}

	.hamburger-input:checked + .hamburger-btn .line-1 {
		transform: translate(0, 5px) rotate(45deg);
	}

	.hamburger-input:checked + .hamburger-btn .line-2 {
		opacity: 0;
	}

	.hamburger-input:checked + .hamburger-btn .line-3 {
		transform: translate(0, -5px) rotate(-45deg);
	}

	.menu-overlay {
		position: fixed;
		top: 0;
		right: -320px;
		width: 320px;
		height: 100vh;
		background: white;
		padding: 2rem;
		z-index: 1002;
		transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: -5px 0 25px rgba(0, 0, 0, 0.1);
	}

	.menu-overlay.open {
		right: 0;
	}

	.menu-nav {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		margin-top: 4rem;
	}

	.menu-link {
		text-decoration: none;
		color: #111827;
		font-size: 1.125rem;
		font-weight: 500;
		padding: 1rem 0;
		border-bottom: 1px solid #F3F4F6;
		transition: all 0.3s ease;
	}

	.menu-link:hover {
		color: #C8A96E;
		padding-left: 1rem;
	}

	@media (max-width: 768px) {
		.menu-overlay {
			width: 280px;
			right: -280px;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const hamburgerInput = document.querySelector('.hamburger-input') as HTMLInputElement;
		const menuOverlay = document.querySelector('.menu-overlay');
		const menuLinks = document.querySelectorAll('.menu-link');

		function toggleMenu() {
			if (hamburgerInput?.checked) {
				menuOverlay?.classList.add('open');
				document.body.style.overflow = 'hidden';
			} else {
				menuOverlay?.classList.remove('open');
				document.body.style.overflow = '';
			}
		}

		hamburgerInput?.addEventListener('change', toggleMenu);

		menuLinks.forEach(link => {
			link.addEventListener('click', function() {
				menuOverlay?.classList.remove('open');
				if (hamburgerInput) hamburgerInput.checked = false;
				document.body.style.overflow = '';
			});
		});

		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape') {
				menuOverlay?.classList.remove('open');
				if (hamburgerInput) hamburgerInput.checked = false;
				document.body.style.overflow = '';
			}
		});
	});
</script>
