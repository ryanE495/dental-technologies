---
---

<section class="hero">
	<div class="container">
		<div class="hero-content">
			<h1 class="massive-headline">
				<span class="line-one">
					<span class="word" style="animation-delay: 0.1s;">dental</span>
					<span class="word space" style="animation-delay: 0.3s;"></span>
					<span class="word" style="animation-delay: 0.5s;">technologies</span>
				</span>
				<span class="line-two">
					<span class="word-group">lab</span>
					<span class="loading-teeth">
						<svg class="tooth tooth-1" viewBox="0 0 24 32" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2C8.5 2 5.5 4.5 5 8c-.3 2 .2 4 1 5.5.5 1 .8 2 .7 3l-.7 8c-.2 2 1.2 3.5 3 3.5 1.2 0 2-.6 2.5-1.5L12 25l.5 1.5c.5.9 1.3 1.5 2.5 1.5 1.8 0 3.2-1.5 3-3.5l-.7-8c-.1-1 .2-2 .7-3 .8-1.5 1.3-3.5 1-5.5C18.5 4.5 15.5 2 12 2z" fill="currentColor"/>
						</svg>
						<svg class="tooth tooth-2" viewBox="0 0 24 32" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2C8.5 2 5.5 4.5 5 8c-.3 2 .2 4 1 5.5.5 1 .8 2 .7 3l-.7 8c-.2 2 1.2 3.5 3 3.5 1.2 0 2-.6 2.5-1.5L12 25l.5 1.5c.5.9 1.3 1.5 2.5 1.5 1.8 0 3.2-1.5 3-3.5l-.7-8c-.1-1 .2-2 .7-3 .8-1.5 1.3-3.5 1-5.5C18.5 4.5 15.5 2 12 2z" fill="currentColor"/>
						</svg>
						<svg class="tooth tooth-3" viewBox="0 0 24 32" xmlns="http://www.w3.org/2000/svg">
							<path d="M12 2C8.5 2 5.5 4.5 5 8c-.3 2 .2 4 1 5.5.5 1 .8 2 .7 3l-.7 8c-.2 2 1.2 3.5 3 3.5 1.2 0 2-.6 2.5-1.5L12 25l.5 1.5c.5.9 1.3 1.5 2.5 1.5 1.8 0 3.2-1.5 3-3.5l-.7-8c-.1-1 .2-2 .7-3 .8-1.5 1.3-3.5 1-5.5C18.5 4.5 15.5 2 12 2z" fill="currentColor"/>
						</svg>
					</span>
				</span>
			</h1>
			
			<p class="hero-description">
				Custom crowns, bridges, veneers, and implant restorations — handcrafted with decades of expertise. We partner with dental practices across the region to deliver work that fits perfectly, looks natural, and lasts.
			</p>
			
			<a href="#contact" class="minimal-button">Get Started</a>
			
			<div class="subtle-circle"></div>
			<div class="subtle-circle-two"></div>
			<div class="subtle-circle-three"></div>
			<div class="subtle-circle-four"></div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 80vh;
		background: #efeeea;
		display: flex;
		align-items: flex-start;
		justify-content: flex-start;
		position: relative;
		padding: 4rem 0 3rem 0;
		overflow: hidden;
	}

	.hero-content {
		text-align: left;
		max-width: 1200px;
		width: 100%;
		margin: 0 auto;
		position: relative;
		z-index: 1;
		padding: 0 1.5rem;
	}

	.massive-headline {
		margin-top: 0;
		font-size: clamp(3rem, 10vw, 9rem);
		font-weight: 300;
		line-height: 0.75;
		color: #111827;
		margin-bottom: 3rem;
		letter-spacing: -0.02em;
		font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif;
		margin-top: -1rem;
	}

	.line-one {
		display: inline;
		margin-right: 1rem;
		white-space: nowrap;
	}

	.line-two {
		display: block;
		margin-top: clamp(1.5rem, 4vw, 3rem);
	}

	.word {
		display: inline-block;
		opacity: 0;
		animation: wordFadeIn 0.6s ease-out forwards;
	}

	.word.space {
		display: inline-block;
		width: 0.02em;
	}

	.word-group {
		opacity: 0;
		animation: fadeInUp 0.6s ease-out 1.0s forwards;
		color: #C8A96E;
	}

	.loading-teeth {
		display: inline-flex;
		align-items: flex-end;
		gap: 4px;
		margin-left: 8px;
		vertical-align: baseline;
		opacity: 0;
		animation: fadeInUp 0.6s ease-out 1.4s forwards;
	}

	.tooth {
		width: 8px;
		height: 11px;
		color: #C8A96E;
		flex-shrink: 0;
		animation: toothBounce 2.4s ease-in-out infinite;
	}

	.tooth-1 { animation-delay: 1.6s; }
	.tooth-2 { animation-delay: 2.0s; }
	.tooth-3 { animation-delay: 2.4s; }

	@keyframes toothBounce {
		0%, 70%, 100% {
			opacity: 0.35;
			transform: translateY(0);
		}
		35% {
			opacity: 0.7;
			transform: translateY(-2px);
		}
	}

	@keyframes wordFadeIn {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(15px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.supporting-text {
		font-size: clamp(1rem, 2.5vw, 1.125rem);
		color: #6B7280;
		margin-bottom: 1.5rem;
		font-weight: 400;
		line-height: 1.6;
		max-width: 500px;
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
	}

	.hero-description {
		font-size: 1rem;
		color: #6B7280;
		line-height: 1.7;
		max-width: 550px;
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
		margin-bottom: clamp(3rem, 6vw, 5rem);
		opacity: 0;
		animation: fadeInUp 0.8s ease-out 1.5s forwards;
	}

	.cursor {
		color: #C8A96E;
		animation: blink 1s infinite;
	}

	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	.minimal-button {
		display: inline-block;
		padding: clamp(0.875rem, 2vw, 1rem) clamp(2rem, 4vw, 2.5rem);
		background-color: #111827;
		color: white;
		text-decoration: none;
		font-size: clamp(0.8rem, 2vw, 1rem);
		font-weight: 500;
		border-radius: 0;
		transition: all 0.3s ease;
		letter-spacing: 0.025em;
		text-transform: uppercase;
	}

	.minimal-button:hover {
		background-color: #C8A96E;
		transform: translateY(-1px);
		box-shadow: 0 10px 25px rgba(200, 169, 110, 0.3);
	}

	.subtle-circle {
		position: absolute;
		top: 50%;
		right: -200px;
		width: 300px;
		height: 300px;
		border: 1px solid rgba(200, 169, 110, 0.25);
		border-radius: 50%;
		transform: translateY(-50%);
		pointer-events: none;
	}

	.subtle-circle-two {
		position: absolute;
		top: 20%;
		left: -150px;
		width: 200px;
		height: 200px;
		border: 1px solid rgba(200, 169, 110, 0.20);
		border-radius: 50%;
		pointer-events: none;
	}

	.subtle-circle-three {
		position: absolute;
		bottom: 10%;
		right: -100px;
		width: 150px;
		height: 150px;
		border: 1px solid rgba(200, 169, 110, 0.18);
		border-radius: 50%;
		pointer-events: none;
	}

	.subtle-circle-four {
		position: absolute;
		top: 10%;
		right: 20%;
		width: 80px;
		height: 80px;
		border: 1px solid rgba(200, 169, 110, 0.15);
		border-radius: 50%;
		pointer-events: none;
	}

	@media (max-width: 1200px) {
		.subtle-circle,
		.subtle-circle-two,
		.subtle-circle-three,
		.subtle-circle-four {
			display: none;
		}
	}

	@media (max-width: 768px) {
		.hero {
			padding: 4rem 0 0 0;
			min-height: 80vh;
		}

		.hero-content {
			padding: 0 0.75rem;
			max-width: 100%;
		}

		.massive-headline {
			margin-bottom: 1.5rem;
			text-align: center;
			line-height: 0.85;
		}

		.line-two {
			margin-top: 1rem;
		}

		.supporting-text {
			margin-bottom: 1rem;
			text-align: center;
			max-width: 100%;
		}

		.minimal-button {
			display: block;
			text-align: center;
			width: fit-content;
			margin: 0 auto;
		}
	}

	@media (max-width: 480px) {
		.hero {
			padding: 3rem 0 0 0;
			min-height: 70vh;
		}

		.hero-content {
			padding: 0 0.5rem;
		}

		.massive-headline {
			margin-bottom: 1rem;
			line-height: 0.9;
		}

		.line-two {
			margin-top: 0.5rem;
		}

		.supporting-text {
			margin-bottom: 0.5rem;
			font-size: 0.95rem;
		}

		.minimal-button {
			padding: 0.75rem 1.5rem;
			font-size: 0.75rem;
		}
	}
</style>
