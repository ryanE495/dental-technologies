---
const services = [
  { num: '01', title: 'Crowns & Bridges', desc: 'Full-contour zirconia, PFM, all-ceramic' },
  { num: '02', title: 'Veneers & Laminates', desc: 'Ultra-thin porcelain, custom shade-matching' },
  { num: '03', title: 'Implant Restorations', desc: 'Custom abutments, all major systems' },
  { num: '04', title: 'Dentures & Partials', desc: 'Full/partial, premium teeth, characterized gingival tones' },
  { num: '05', title: 'Custom Shades', desc: 'Expert shade-matching, staining, characterization' },
  { num: '06', title: 'Digital Impressions', desc: 'All major intraoral scanners, digital workflows' },
];
---

<section id="services" class="services-section">
  <div class="services-container">
    <div class="services-left">
      <div class="services-left-inner">
        <div class="gold-line"></div>
        <h2 class="services-title">what we do</h2>
        <p class="services-subtitle">
          <span class="typewriter-text"></span><span class="typewriter-cursor">|</span>
        </p>
        <div class="arrow-container" id="services-arrow-container">
          <svg width="48" viewBox="0 0 48 120" fill="none" xmlns="http://www.w3.org/2000/svg" style="height:120px;">
            <path id="services-arrow-stem" d="M24 12L24 80" stroke="#437eae" stroke-width="2" stroke-linecap="round"/>
            <path id="services-arrow-head" d="M8 68L24 80L40 68" stroke="#437eae" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
      </div>
    </div>
    <div class="services-cards">
      {services.map((s, i) => (
        <div class="service-card animate-on-scroll" style={`transition-delay: ${i * 0.1}s`}>
          <span class="card-num">{s.num}</span>
          <h3 class="card-title">{s.title}</h3>
          <p class="card-desc">{s.desc}</p>
        </div>
      ))}
    </div>

    <div class="subtle-square"></div>
    <div class="subtle-square-two"></div>
    <div class="subtle-square-three"></div>
  </div>
</section>

<style>
  :global(.animate-on-scroll) {
    opacity: 0 !important;
    transform: translateY(30px) !important;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }
  :global(.animate-on-scroll.animate-in) {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  .services-section {
    background: #efeeea;
    padding: 6rem 0 4rem 0;
    overflow: hidden;
    position: relative;
  }

  .services-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }

  .services-left {
    position: sticky;
    top: 6rem;
    z-index: 1;
  }

  .services-left-inner {
    position: relative;
  }

  .gold-line {
    width: 48px;
    height: 3px;
    background: #437eae;
    margin-bottom: 1rem;
  }

  .services-title {
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    font-size: 2.5rem;
    color: #111827;
    margin: 0 0 0.75rem 0;
    text-transform: lowercase;
    cursor: pointer;
    transition: color 0.3s ease;
  }

  .services-title:hover {
    color: #437eae;
  }

  .services-subtitle {
    font-family: 'NeueHaasDisplayThin', Inter, sans-serif;
    font-size: 1.1rem;
    color: #6B7280;
    margin: 0 0 2rem 0;
    min-height: 1.5em;
  }

  .typewriter-cursor {
    color: #437eae;
    animation: blink 0.8s step-end infinite;
    font-weight: 300;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .arrow-container {
    position: absolute;
    top: auto;
    left: 0;
    height: 120px;
    overflow: visible;
    pointer-events: none;
  }

  .services-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    z-index: 1;
    position: relative;
  }

  .service-card {
    background: #f8f9fa;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 1.75rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #437eae, #6fa3d4);
    transform: translateX(-100%);
    transition: transform 0.4s ease;
  }

  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .service-card:hover::before {
    transform: translateX(0);
  }

  .card-num {
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    color: #437eae;
    font-size: 0.9rem;
    font-weight: 600;
    display: block;
    margin-bottom: 0.5rem;
  }

  .card-title {
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    color: #111827;
    font-size: 1.15rem;
    margin: 0 0 0.5rem 0;
  }

  .card-desc {
    font-family: 'NeueHaasDisplayThin', Inter, sans-serif;
    color: #6B7280;
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.5;
  }

  .subtle-square {
    position: absolute;
    top: 15%;
    right: -180px;
    width: 250px;
    height: 250px;
    border: 1.5px solid rgba(67, 126, 174, 0.08);
    transform: rotate(0deg);
    pointer-events: none;
    z-index: 0;
  }

  .subtle-square-two {
    position: absolute;
    bottom: 20%;
    left: -120px;
    width: 180px;
    height: 180px;
    border: 1.5px solid rgba(67, 126, 174, 0.06);
    transform: rotate(0deg);
    pointer-events: none;
    z-index: 0;
  }

  .subtle-square-three {
    position: absolute;
    bottom: 5%;
    right: 10%;
    width: 100px;
    height: 100px;
    border: 1.5px solid rgba(67, 126, 174, 0.04);
    transform: rotate(0deg);
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 1200px) {
    .subtle-square {
      right: -200px;
      width: 170px;
      height: 170px;
    }
    .subtle-square-two {
      left: -100px;
      width: 120px;
      height: 120px;
    }
    .subtle-square-three {
      right: 3%;
      width: 70px;
      height: 70px;
    }
  }

  @media (max-width: 768px) {
    .services-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .services-left {
      position: relative;
      top: 0;
    }
    .arrow-container {
      display: none;
    }
    .services-cards {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Typewriter - trigger on scroll entry
    const text = 'precision craftsmanship for every restoration';
    const el = document.querySelector('.typewriter-text');
    const servicesSection = document.getElementById('services');
    if (el && servicesSection) {
      const typeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            let i = 0;
            const type = () => {
              if (i < text.length) {
                el.textContent += text[i];
                i++;
                setTimeout(type, 50);
              }
            };
            setTimeout(type, 300);
            typeObserver.disconnect();
          }
        });
      }, { threshold: 0.3 });
      typeObserver.observe(servicesSection);
    }

    // Arrow
    const section = document.getElementById('services');
    const arrowContainer = document.getElementById('services-arrow-container');
    const arrowStem = document.getElementById('services-arrow-stem');
    const arrowHead = document.getElementById('services-arrow-head');
    if (!section || !arrowContainer || !arrowStem || !arrowHead) return;

    function updateArrow() {
      const rect = section.getBoundingClientRect();
      const rightCol = document.querySelector('.services-cards') as HTMLElement | null;
      const maxH = rightCol ? rightCol.offsetHeight - 40 : 400;
      const wh = window.innerHeight;
      let progress = 0;
      if (rect.top <= wh && rect.bottom >= 0 && rect.top <= wh * 0.5) {
        progress = Math.min(1, Math.max(0, wh * 0.5 - rect.top) / (maxH * 1.5));
      }
      const h = 80 + (progress * (maxH - 80));
      arrowContainer.style.height = h + 'px';
      const svg = arrowContainer.querySelector('svg');
      if (svg) {
        svg.setAttribute('viewBox', '0 0 48 ' + Math.max(42, h));
        svg.style.height = h + 'px';
      }
      const stemEnd = 22 + (progress * (h - 60));
      arrowStem.setAttribute('d', 'M24 12L24 ' + stemEnd);
      arrowHead.setAttribute('d', 'M8 ' + Math.max(12, stemEnd - 12) + 'L24 ' + stemEnd + 'L40 ' + Math.max(12, stemEnd - 12));
    }
    window.addEventListener('scroll', updateArrow);
    updateArrow();

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  });
</script>
