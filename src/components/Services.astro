---
---

<section id="services" class="services section-padding">
	<div class="container">
		<div class="subtle-circle"></div>
		<div class="subtle-circle-two"></div>
		<div class="subtle-circle-three"></div>
		
		<div class="services-layout">
			<div class="section-header animate-on-scroll">
				<h2>what we do</h2>
				<div class="accent-line"></div>
				<p class="section-subtitle">Comprehensive restorative solutions crafted with precision and care</p>
				<div class="scroll-arrow">
					<svg width="64" height="42" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path id="arrow-head" d="M8 12L24 24L40 12" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
						<path id="arrow-stem" d="M24 12L24 22" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</div>
			</div>
			
			<div class="services-cards">
				<div class="service-card animate-on-scroll">
					<div class="card-number">01</div>
					<h3>Crowns & Bridges</h3>
					<p>Full-contour zirconia, porcelain-fused-to-metal, and all-ceramic crowns and bridges. Each restoration is precision-milled and hand-finished for optimal fit and aesthetics.</p>
				</div>
				
				<div class="service-card animate-on-scroll">
					<div class="card-number">02</div>
					<h3>Veneers & Laminates</h3>
					<p>Ultra-thin porcelain veneers and laminates that transform smiles. Custom shade-matching and layering techniques deliver lifelike translucency and natural beauty.</p>
				</div>
				
				<div class="service-card animate-on-scroll">
					<div class="card-number">03</div>
					<h3>Implant Restorations</h3>
					<p>Custom abutments and implant-supported crowns, bridges, and hybrid prosthetics. Compatible with all major implant systems for seamless integration.</p>
				</div>
				
				<div class="service-card animate-on-scroll">
					<div class="card-number">04</div>
					<h3>Dentures & Partials</h3>
					<p>Full and partial dentures fabricated with premium teeth and characterized gingival tones. Designed for comfort, function, and a natural appearance.</p>
				</div>
				
				<div class="service-card animate-on-scroll">
					<div class="card-number">05</div>
					<h3>Custom Shades</h3>
					<p>Expert shade-matching services including custom staining, characterization, and photography-assisted color verification to ensure every restoration blends seamlessly.</p>
				</div>
				
				<div class="service-card animate-on-scroll">
					<div class="card-number">06</div>
					<h3>Digital Impressions</h3>
					<p>We accept digital impressions from all major intraoral scanners. Streamlined digital workflows mean faster turnaround and exceptional accuracy for your cases.</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.services {
		background-color: #efeeea;
		padding: 8rem 0;
		position: relative;
		overflow: hidden;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.services-layout {
		display: grid;
		grid-template-columns: 1fr 1.5fr;
		gap: 4rem;
		align-items: flex-start;
	}

	.section-header {
		text-align: left;
		position: sticky;
		top: 2rem;
	}

	.section-header h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 300;
		line-height: 1.3;
		color: #111827;
		margin-bottom: 1.5rem;
		letter-spacing: -0.01em;
		font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif;
		cursor: pointer;
		transition: color 0.3s ease;
	}

	.section-header h2:hover {
		color: #C8A96E;
	}

	.accent-line {
		width: 200px;
		height: 4px;
		background-color: #C8A96E;
		margin-bottom: 2rem;
	}

	.section-subtitle {
		font-size: 1.125rem;
		line-height: 1.6;
		color: #6B7280;
		font-weight: 400;
		max-width: 400px;
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
		overflow: hidden;
		white-space: nowrap;
		width: 0;
		border-right: 2px solid #C8A96E;
		animation: typewriter 3s steps(60, end) forwards, blinkCursor 0.8s infinite;
		animation-play-state: paused;
	}

	.section-subtitle.start-typing {
		animation-play-state: running;
	}

	@keyframes typewriter {
		from { width: 0; }
		to { width: 100%; }
	}

	@keyframes blinkCursor {
		from, to { border-color: transparent; }
		50% { border-color: #C8A96E; }
	}

	/* Scroll Arrow */
	.scroll-arrow {
		margin-top: 2rem;
		margin-left: 3rem;
		display: flex;
		justify-content: flex-start;
		align-items: center;
		color: #C8A96E;
		height: 120px;
		max-height: 1200px;
		overflow: visible;
		position: relative;
		z-index: 10;
		pointer-events: none;
	}

	.scroll-arrow svg {
		height: auto;
		min-height: 32px;
		max-height: 1200px;
		overflow: visible;
		width: 48px;
		pointer-events: none;
	}

	/* Subtle circles */
	.subtle-circle {
		position: absolute;
		top: 20%;
		left: -200px;
		width: 300px;
		height: 300px;
		border: 1px solid rgba(200, 169, 110, 0.15);
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}

	.subtle-circle-two {
		position: absolute;
		bottom: 10%;
		left: -100px;
		width: 200px;
		height: 200px;
		border: 1px solid rgba(200, 169, 110, 0.12);
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}

	.subtle-circle-three {
		position: absolute;
		top: 50%;
		left: 5%;
		width: 100px;
		height: 100px;
		border: 1px solid rgba(200, 169, 110, 0.10);
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}

	:global(.animate-on-scroll) {
		opacity: 0 !important;
		transform: translateY(30px) !important;
		transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1) !important;
	}

	:global(.animate-on-scroll.animate-in) {
		opacity: 1 !important;
		transform: translateY(0) !important;
	}

	.services-cards {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
	}

	.service-card {
		padding: 2.5rem 2rem;
		background: #f8f9fa;
		border: 1px solid #E5E7EB;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}

	.service-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 2px;
		background: linear-gradient(90deg, transparent, #C8A96E, transparent);
		transition: left 0.6s ease;
	}

	.service-card:hover::before {
		left: 100%;
	}

	.service-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 15px 35px rgba(200, 169, 110, 0.1);
		background: white;
	}

	.card-number {
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
		font-size: 0.8rem;
		color: #C8A96E;
		letter-spacing: 0.15em;
		margin-bottom: 1.5rem;
	}

	.service-card h3 {
		font-size: 1.25rem;
		font-weight: 400;
		color: #111827;
		margin-bottom: 1rem;
		font-family: 'NeueHaasDisplayRoman', 'Inter', sans-serif;
	}

	.service-card p {
		font-size: 0.95rem;
		line-height: 1.7;
		color: #6B7280;
		font-family: 'NeueHaasDisplayThin', 'Inter', sans-serif;
	}

	@media (max-width: 1200px) {
		.subtle-circle,
		.subtle-circle-two,
		.subtle-circle-three {
			display: none;
		}
	}

	@media (max-width: 1024px) {
		.services-layout {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.section-header {
			position: static;
		}

		.scroll-arrow {
			display: none;
		}

		.services-cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.services {
			padding: 4rem 0;
		}

		.section-header {
			text-align: center;
		}

		.accent-line {
			margin-left: auto;
			margin-right: auto;
		}

		.section-subtitle {
			animation: none !important;
			white-space: normal;
			border-right: none;
			width: auto;
			text-align: center;
			max-width: 100%;
		}

		.services-cards {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.service-card {
			padding: 2rem 1.5rem;
		}
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const servicesSection = document.querySelector('#services');
		const subtitle = document.querySelector('#services .section-subtitle');
		
		if (!servicesSection) return;

		// Scroll reveal animations
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const elements = entry.target.querySelectorAll('.animate-on-scroll');
					elements.forEach((el, i) => {
						setTimeout(() => el.classList.add('animate-in'), i * 150);
					});
					
					if (subtitle) {
						setTimeout(() => subtitle.classList.add('start-typing'), 700);
					}
					
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.2, rootMargin: '0px 0px -20% 0px' });

		observer.observe(servicesSection);

		// Expanding arrow on scroll
		const arrowStem = document.querySelector('#services .scroll-arrow #arrow-stem');
		const arrowHead = document.querySelector('#services .scroll-arrow #arrow-head');
		const scrollArrowContainer = document.querySelector('#services .scroll-arrow');
		
		function updateArrowStem() {
			if (!arrowStem || !arrowHead || !servicesSection || !scrollArrowContainer) return;
			
			const rect = servicesSection.getBoundingClientRect();
			const sectionHeight = servicesSection.offsetHeight;
			const windowHeight = window.innerHeight;
			
			let progress = 0;
			
			if (rect.top <= windowHeight && rect.bottom >= 0) {
				if (rect.top <= windowHeight * 0.5) {
					const triggerPoint = windowHeight * 0.5;
					const scrolledDistance = Math.max(0, triggerPoint - rect.top);
					const totalAnimationDistance = sectionHeight * 0.8;
					progress = Math.min(1, scrolledDistance / Math.max(totalAnimationDistance, 1));
				}
			}
			
			const baseContainerHeight = 120;
			const maxContainerHeight = Math.min(1200, sectionHeight * 1.0);
			const currentContainerHeight = baseContainerHeight + (progress * (maxContainerHeight - baseContainerHeight));
			scrollArrowContainer.style.height = `${currentContainerHeight}px`;
			
			const arrowSvg = scrollArrowContainer.querySelector('svg');
			if (arrowSvg) {
				const viewBoxHeight = Math.max(42, currentContainerHeight);
				arrowSvg.setAttribute('viewBox', `0 0 64 ${viewBoxHeight}`);
				arrowSvg.style.height = `${currentContainerHeight}px`;
			}
			
			const baseStemEnd = 22;
			const maxStemEnd = currentContainerHeight - 60;
			const currentStemEnd = baseStemEnd + (progress * (maxStemEnd - baseStemEnd));
			
			arrowStem.setAttribute('d', `M24 12L24 ${currentStemEnd}`);
			
			const arrowHeadY = Math.max(12, currentStemEnd - 15);
			const arrowTipY = currentStemEnd;
			
			arrowHead.setAttribute('d', `M8 ${arrowHeadY}L24 ${arrowTipY}L40 ${arrowHeadY}`);
		}
		
		window.addEventListener('scroll', updateArrowStem);
		updateArrowStem();
	});
</script>
