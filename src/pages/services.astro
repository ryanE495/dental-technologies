---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'crowns-bridges',
    num: '01',
    title: 'Crowns & Bridges',
    summary: 'Full-contour zirconia, porcelain-fused-to-metal, and all-ceramic restorations crafted with precision fit and natural aesthetics.',
    details: [
      'Full-contour zirconia (monolithic & layered)',
      'Porcelain-fused-to-metal (PFM)',
      'All-ceramic / e.max',
      'Implant-supported crowns',
      'Maryland & cantilever bridges',
      'Same-day digital design available',
    ],
  },
  {
    id: 'veneers',
    num: '02',
    title: 'Veneers & Laminates',
    summary: 'Ultra-thin porcelain veneers with custom shade matching for seamless, natural-looking smile transformations.',
    details: [
      'Porcelain veneers (feldspathic & pressed)',
      'Ultra-thin no-prep laminates',
      'Custom shade matching & staining',
      'Smile design collaboration',
      'Wax-up previews available',
      'Consistent color across full arches',
    ],
  },
  {
    id: 'implant-restorations',
    num: '03',
    title: 'Implant Restorations',
    summary: 'Custom abutments and implant-supported prosthetics compatible with all major implant systems.',
    details: [
      'Custom titanium & zirconia abutments',
      'Screw-retained & cement-retained crowns',
      'All-on-4 / All-on-6 hybrid prosthetics',
      'Compatible with Nobel, Straumann, Zimmer & more',
      'Digital implant planning integration',
      'Bar-retained overdentures',
    ],
  },
  {
    id: 'dentures-partials',
    num: '04',
    title: 'Dentures & Partials',
    summary: 'Full and partial dentures with premium teeth, characterized gingival tones, and comfortable precision fit.',
    details: [
      'Full conventional dentures',
      'Immediate dentures',
      'Cast metal partial frameworks',
      'Flexible partials (Valplast)',
      'Premium teeth selection',
      'Characterized gingival tones & stippling',
    ],
  },
  {
    id: 'custom-shades',
    num: '05',
    title: 'Custom Shade Matching',
    summary: 'Expert shade analysis with over 20 years of experience — creating restorations that disappear into natural dentition.',
    details: [
      'In-person shade appointments available',
      'Custom staining & characterization',
      'Digital shade analysis',
      'Cross-reference with patient photos',
      'Multi-layered color matching',
      'Expertise across all ceramic systems',
    ],
  },
  {
    id: 'digital-workflow',
    num: '06',
    title: 'Digital Impressions & CAD/CAM',
    summary: 'Fully digital workflows accepting all major intraoral scanners for faster, more accurate restorations.',
    details: [
      'Accept all major intraoral scanners',
      'In-house CAD/CAM milling',
      '3D printing for models & guides',
      'Digital design preview before fabrication',
      'Faster turnaround with digital cases',
      'STL / PLY / DCM file compatible',
    ],
  },
];
---

<Layout title="Our Services — Dental Technologies Lab" description="Full-service dental lab offering crowns, bridges, veneers, implant restorations, dentures, custom shades, and digital CAD/CAM workflows.">
  <Header />
  <main>

    <!-- Hero -->
    <section class="services-hero">
      <div class="hero-content">
        <span class="hero-label hero-load" style="--delay: 0s">OUR SERVICES</span>
        <h1 class="hero-title hero-load" style="--delay: 0.15s">
          <span class="line">precision for</span>
          <span class="line accent">every <span class="blue">restoration</span></span>
        </h1>
        <p class="hero-description hero-load" style="--delay: 0.3s">
          From single crowns to full-arch rehabilitations, every case receives the same 
          meticulous attention to detail. We combine decades of hand-craftsmanship with 
          modern digital workflows to deliver restorations your patients will love.
        </p>
      </div>
      <div class="subtle-square sq-1"></div>
      <div class="subtle-square sq-2"></div>
      <div class="subtle-square sq-3"></div>
    </section>

    <!-- Services Section — Two-column layout matching site pattern -->
    <section class="services-section">
      <div class="services-layout">
        <div class="services-left">
          <div class="services-left-inner">
            <div class="accent-line"></div>
            <h2 class="section-title">what we do</h2>
            <p class="section-subtitle">
              <span class="typewriter-text" id="services-typewriter"></span><span class="typewriter-cursor">|</span>
            </p>
            <div class="arrow-container" id="services-arrow-container">
              <svg viewBox="0 0 48 80" width="48" height="80" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path id="services-arrow-stem" d="M24 12L24 22" stroke="#437eae" stroke-width="2" stroke-linecap="round"/>
                <path id="services-arrow-head" d="M8 12L24 22L40 12" stroke="#437eae" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              </svg>
            </div>
          </div>
        </div>
        <div class="services-right">
          {services.map((service, i) => (
            <div class="service-block animate-on-scroll" id={service.id} style={`transition-delay: ${i * 0.08}s`}>
              <span class="block-number">{service.num}</span>
              <h3>{service.title}</h3>
              <p class="block-summary">{service.summary}</p>
              <ul class="block-details">
                {service.details.map(d => (
                  <li>{d}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
      <div class="subtle-square sq-4"></div>
      <div class="subtle-square sq-5"></div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="cta-layout">
        <div class="cta-left">
          <div class="cta-left-inner">
            <div class="accent-line accent-line--light"></div>
            <h2 class="section-title section-title--light">get started</h2>
          </div>
        </div>
        <div class="cta-right">
          <div class="cta-block animate-on-scroll">
            <p class="cta-text">
              Send us your first case or schedule a consultation. We'll show you 
              what precision lab work really looks like.
            </p>
            <div class="cta-buttons">
              <a href="/contact" class="btn-primary">Contact Us</a>
              <a href="tel:+19709451840" class="btn-secondary">Call (970) 945-1840</a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ===== GLOBAL ===== */
  :global(.animate-on-scroll) {
    opacity: 0 !important;
    transform: translateY(30px) !important;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }
  :global(.animate-on-scroll.animate-in) {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  /* ===== HERO ===== */
  .services-hero {
    background: #efeeea;
    min-height: 70vh;
    display: flex;
    align-items: flex-start;
    padding: 8rem 0 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero-content {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .hero-label {
    display: inline-block;
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    font-size: 0.75rem;
    letter-spacing: 3px;
    color: #437eae;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    padding: 6px 16px;
    border: 1px solid rgba(67,126,174,0.3);
    border-radius: 2px;
  }
  .hero-title {
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    line-height: 1.12;
    color: #111827;
    margin: 0 0 1.5rem;
  }
  .hero-title .line { display: block; }
  .hero-title .accent {
    font-family: 'NeueHaasDisplayThin', Inter, sans-serif;
    font-weight: 200;
  }
  .hero-title .blue { color: #437eae; }
  .hero-description {
    font-family: 'NeueHaasDisplayThin', Inter, sans-serif;
    font-size: 1.15rem;
    line-height: 1.7;
    color: #6B7280;
    max-width: 560px;
  }
  .hero-load {
    opacity: 0;
    transform: translateY(24px);
    animation: heroFadeUp 0.7s ease forwards;
    animation-delay: var(--delay, 0s);
  }
  @keyframes heroFadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== SUBTLE SQUARES ===== */
  .subtle-square {
    position: absolute;
    border: 2px solid rgba(67,126,174,0.08);
    pointer-events: none;
    z-index: 0;
  }
  .sq-1 { width: 300px; height: 300px; top: -60px; right: 5%; }
  .sq-2 { width: 180px; height: 180px; bottom: -40px; right: 25%; }
  .sq-3 { width: 120px; height: 120px; top: 30%; right: 15%; border-color: rgba(67,126,174,0.05); }
  .sq-4 { width: 250px; height: 250px; top: 10%; right: -120px; }
  .sq-5 { width: 160px; height: 160px; bottom: 15%; left: -80px; border-color: rgba(67,126,174,0.06); }

  /* ===== SERVICES SECTION ===== */
  .services-section {
    background: #efeeea;
    padding: 6rem 0 4rem;
    position: relative;
    overflow: hidden;
  }
  .services-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  /* Left column — sticky */
  .services-left {
    position: sticky;
    top: 6rem;
    z-index: 1;
  }
  .services-left-inner { position: relative; }
  .accent-line {
    width: 48px;
    height: 3px;
    background: #437eae;
    margin-bottom: 1rem;
  }
  .accent-line--light {
    background: #437eae;
  }
  .section-title {
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    font-size: 2.5rem;
    color: #111827;
    margin: 0 0 0.75rem;
    text-transform: lowercase;
  }
  .section-title--light { color: #ffffff; }
  .section-subtitle {
    font-family: 'NeueHaasDisplayThin', Inter, sans-serif;
    font-size: 1.1rem;
    color: #6B7280;
    margin: 0 0 2rem;
    min-height: 1.5em;
  }
  .typewriter-cursor {
    color: #437eae;
    animation: blink 0.8s step-end infinite;
    font-weight: 300;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .arrow-container {
    position: absolute;
    top: auto;
    left: 0;
    height: 80px;
    overflow: visible;
    pointer-events: none;
  }

  /* Right column — service blocks */
  .services-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    z-index: 1;
  }
  .service-block {
    background: #f8f7f4;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 2.25rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .service-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #437eae, #6fa3d4);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .service-block:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.06);
  }
  .service-block:hover::before {
    transform: scaleX(1);
  }
  .block-number {
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    color: #437eae;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 1px;
    display: block;
    margin-bottom: 0.5rem;
  }
  .service-block h3 {
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    color: #111827;
    font-size: 1.3rem;
    margin: 0 0 0.75rem;
  }
  .block-summary {
    font-family: 'NeueHaasDisplayThin', Inter, sans-serif;
    color: #6B7280;
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }
  .block-details {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid #E5E7EB;
    padding-top: 1rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 16px;
  }
  .block-details li {
    font-family: 'NeueHaasDisplayThin', Inter, sans-serif;
    font-size: 0.85rem;
    color: #4B5563;
    padding: 4px 0 4px 16px;
    position: relative;
    line-height: 1.5;
  }
  .block-details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 5px;
    height: 5px;
    background: #437eae;
    border-radius: 1px;
  }

  /* ===== CTA SECTION ===== */
  .cta-section {
    background: #1a1a1a;
    padding: 5rem 0 4rem;
    position: relative;
    overflow: hidden;
  }
  .cta-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }
  .cta-left {
    position: relative;
    z-index: 1;
  }
  .cta-right {
    z-index: 1;
  }
  .cta-block {
    max-width: 520px;
  }
  .cta-text {
    font-family: 'NeueHaasDisplayThin', Inter, sans-serif;
    font-size: 1.1rem;
    color: #9CA3AF;
    line-height: 1.7;
    margin: 0 0 2rem;
  }
  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    padding: 14px 36px;
    background: #437eae;
    color: white;
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    font-size: 0.9rem;
    text-decoration: none;
    border-radius: 4px;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }
  .btn-primary:hover {
    background: #356a96;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(67,126,174,0.3);
  }
  .btn-secondary {
    display: inline-block;
    padding: 14px 36px;
    background: transparent;
    color: #9CA3AF;
    font-family: 'NeueHaasDisplayRoman', Inter, sans-serif;
    font-size: 0.9rem;
    text-decoration: none;
    border: 1px solid rgba(156,163,175,0.3);
    border-radius: 4px;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }
  .btn-secondary:hover {
    color: white;
    border-color: rgba(255,255,255,0.4);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .services-hero {
      min-height: auto;
      padding: 7rem 0 3rem;
    }
    .services-layout,
    .cta-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .services-left {
      position: relative;
      top: 0;
    }
    .arrow-container { display: none; }
    .block-details { grid-template-columns: 1fr; }
    .cta-buttons { flex-direction: column; }
    .cta-buttons a { text-align: center; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Typewriter
    const text = 'precision craftsmanship for every restoration';
    const el = document.getElementById('services-typewriter');
    const section = document.querySelector('.services-section');
    if (el && section) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            let i = 0;
            const type = () => {
              if (i < text.length) {
                el.textContent += text[i];
                i++;
                setTimeout(type, 50);
              }
            };
            setTimeout(type, 300);
            obs.disconnect();
          }
        });
      }, { threshold: 0.3 });
      obs.observe(section);
    }

    // Scroll arrow
    const svc = document.querySelector('.services-section') as HTMLElement | null;
    const arrowC = document.getElementById('services-arrow-container');
    const stem = document.getElementById('services-arrow-stem');
    const head = document.getElementById('services-arrow-head');
    if (svc && arrowC && stem && head) {
      const rightCol = document.querySelector('.services-right') as HTMLElement | null;
      function updateArrow() {
        const rect = svc!.getBoundingClientRect();
        const maxH = rightCol ? rightCol.offsetHeight - 40 : 400;
        const wh = window.innerHeight;
        let progress = 0;
        if (rect.top <= wh && rect.bottom >= 0 && rect.top <= wh * 0.5) {
          progress = Math.min(1, Math.max(0, wh * 0.5 - rect.top) / (maxH * 1.5));
        }
        const h = 80 + (progress * (maxH - 80));
        arrowC!.style.height = h + 'px';
        const svg = arrowC!.querySelector('svg');
        if (svg) {
          svg.setAttribute('viewBox', '0 0 48 ' + Math.max(42, h));
          svg.style.height = h + 'px';
        }
        const stemEnd = 22 + (progress * (h - 60));
        stem!.setAttribute('d', 'M24 12L24 ' + stemEnd);
        head!.setAttribute('d', 'M8 ' + Math.max(12, stemEnd - 12) + 'L24 ' + stemEnd + 'L40 ' + Math.max(12, stemEnd - 12));
      }
      window.addEventListener('scroll', updateArrow);
      updateArrow();
    }

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate-in');
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  });
</script>
</Layout>
